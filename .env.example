# Copy to .env (cp .env.example .env) and fill in. Read by docker-compose.
# .env is gitignored — never commit real secrets.

# Public canonical URL (baked into the client bundle at build time).
NEXT_PUBLIC_SITE_URL=https://ahantime.com

# Data source: "live" (Postgres-backed backend) or "mock" (sample data, no DB).
NEXT_PUBLIC_API_MODE=live

# Free-form label surfaced on /api/health — no behavioral effect, just lets
# you confirm which deployment answered a request (see GEO-ROUTING.md).
NEXT_PUBLIC_DEPLOY_REGION=ir-docker

# Pre-built image tag to run (set automatically on the server by the GitHub
# Actions deploy workflow to ghcr.io/am1eza/iron-web:<git-sha> — see
# docker-compose.yml's comment on the web service and DEPLOY.md's
# "Automatic deploys" section). Leave unset for local
# `docker compose up -d --build`, which builds and tags
# `ghcr.io/am1eza/iron-web:local` from your working tree instead.
# WEB_IMAGE=

# REQUIRED in production. Generate one with:  openssl rand -hex 32
SESSION_SECRET=

# REQUIRED — Postgres password for the bundled db service.
# Generate one with:  openssl rand -hex 16
POSTGRES_PASSWORD=

# Gate /admin behind login (recommended: true in production).
AUTH_ENFORCED=true

# Seed the database with the benchmarked catalog on first boot (idempotent —
# only fills empty tables; set false once you manage the catalog from /admin).
SEED_ON_START=true

# Dev/staging convenience: this mobile becomes the seeded admin account.
# DEV_ADMIN_MOBILE=09120000000

# SMS.ir — REQUIRED with the defaults above (AUTH_ENFORCED=true): OTP login
# has no fallback in live mode, so the app refuses to boot without these.
SMSIR_API_KEY=
SMSIR_TEMPLATE_ID=          # OTP verify template ID from the SMS.ir panel (variable name "Code")
SMSIR_LINE_NUMBER=          # optional — پیش‌فاکتور/alert texts dev-log (not sent) if unset

# ---------------------------------------------------------------------------
# Fully optional integrations. Leave blank to use dev fallbacks:
#   no TGJU_BASE_URL  → ticker serves seeded/last-known values
#   AI_ENABLED=false  → /api/ai/chat returns a polite "unavailable" message
# ---------------------------------------------------------------------------
# TGJU_BASE_URL=
# TGJU_API_KEY=
AI_ENABLED=false
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=        # the out-of-Iran relay endpoint
# DEEPSEEK_MODEL=deepseek-chat

# Server-side error alerting (see web/src/lib/errors/sentry.ts) — a Sentry
# project's DSN, format https://<key>@<host>/<projectId>. Every
# reportError() call (unhandled API errors, job failures, integration
# failures) posts there once this is set; leave blank to keep console-only
# structured logging (the default today).
# SENTRY_DSN=
