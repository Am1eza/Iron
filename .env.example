# Copy to .env (cp .env.example .env) and fill in. Read by docker-compose.
# .env is gitignored — never commit real secrets.

# Public canonical URL (baked into the client bundle at build time).
NEXT_PUBLIC_SITE_URL=https://ahantime.com

# Data source: "mock" (current — realistic sample data) or "live" (backend phase).
NEXT_PUBLIC_API_MODE=mock

# REQUIRED in production. Generate one with:  openssl rand -hex 32
SESSION_SECRET=

# Gate /admin behind login. Keep false until the admin/auth backend is wired.
AUTH_ENFORCED=false

# ---------------------------------------------------------------------------
# Backend phase only — required when NEXT_PUBLIC_API_MODE=live. Leave blank now.
# ---------------------------------------------------------------------------
# DATABASE_URL=
# KAVENEGAR_API_KEY=
# KAVENEGAR_SENDER=
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=        # the out-of-Iran relay endpoint
# DEEPSEEK_MODEL=deepseek-chat
# TGJU_BASE_URL=
