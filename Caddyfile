# Caddy auto-provisions and renews a free Let's Encrypt TLS certificate for these
# hostnames and reverse-proxies to the Next.js container. HTTP is auto-redirected
# to HTTPS. Requires ports 80 + 443 reachable from the internet and the domain's
# DNS A record pointing at this server.
ahantime.com, www.ahantime.com {
	encode zstd gzip

	# Cap request bodies at the edge so oversized uploads are rejected before
	# they reach Next.js (the app also sets client_max_body_size in nginx-land
	# equivalents; this is the outer guard).
	request_body {
		max_size 20MB
	}

	header {
		# Edge HSTS backstop: still sent even if Next.js is down/misroutes and
		# can't emit its own header. (No `preload` — that's a one-way commitment
		# the operator should opt into deliberately.)
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		# Don't leak framework/cache internals to clients.
		-X-Powered-By
		-x-nextjs-cache
		-x-nextjs-prerender
		-x-nextjs-stale-time
	}

	# Content-hashed build assets + self-hosted fonts never change under a given
	# URL — cache them hard so repeat views over Iran latency are instant.
	@immutable path /_next/static/* /fonts/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	# Matomo tracker (same-origin → zero CSP changes): /mt/matomo.js loads the
	# tracking script, /mt/matomo.php receives hits. Only these two files are
	# proxied — the admin UI lives on :8443 below.
	handle /mt/* {
		uri strip_prefix /mt
		reverse_proxy matomo:80
	}

	reverse_proxy web:3000
}

# Matomo admin console — same certificate, separate port (no extra DNS record
# needed). Open 8443/tcp in the firewall.
ahantime.com:8443 {
	encode zstd gzip
	reverse_proxy matomo:80
}

# Admin panel, own subdomain (needs its own DNS A record → this server's IP;
# Caddy auto-provisions a separate TLS cert for it the same way as above).
# Same app/container as ahantime.com — middleware.ts rewrites every path here
# to its /admin/* counterpart (panel.ahantime.com/leads → internally
# /admin/leads), so this is routing-only, not a second deployment.
panel.ahantime.com {
	encode zstd gzip

	request_body {
		max_size 20MB
	}

	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		-X-Powered-By
		-x-nextjs-cache
		-x-nextjs-prerender
		-x-nextjs-stale-time
	}

	@immutable path /_next/static/* /fonts/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	reverse_proxy web:3000
}
