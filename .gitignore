# Local Claude Code settings (holds API keys — never commit)
.claude/settings.local.json

# Secrets / env — never commit. Use .env.example as the template.
.env
.env.local
.env*.local
.env.*
!.env.example
.dev.vars

# Caddy / Docker local state
caddy_data/
caddy_config/

# Pre-deploy DB dumps (deploy.yml's backup step, and manual pre-deploy backups)
# — full database contents, never belongs in git.
backups/

# OS / editor
.DS_Store
