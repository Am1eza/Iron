# ── Poladin Web — environment (copy to .env.local; NEVER commit real secrets) ──

# Public (exposed to the browser — safe)
NEXT_PUBLIC_SITE_URL=https://poladin.com
NEXT_PUBLIC_API_MODE=mock            # mock | live  — start in "mock" (no backend needed)

# ── Server-only secrets (no NEXT_PUBLIC_ prefix; never reach the client) ──
# AI: DeepSeek via the out-of-Iran relay (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://<relay-host>/v1
DEEPSEEK_MODEL=deepseek-chat

# SMS (OTP / پیش‌فاکتور / alerts) — SMS.ir Verify API
SMSIR_API_KEY=
SMSIR_TEMPLATE_ID=                    # numeric template ID from the SMS.ir panel; template must have a "Code" variable

# Market data (ticker) — tgju
TGJU_BASE_URL=
TGJU_API_KEY=

# Auth / sessions
SESSION_SECRET=                       # ≥32 random chars; signs the access JWT (required in live)
AUTH_ENFORCED=false                   # true → middleware gates /admin on the session cookie
DEV_ADMIN_MOBILE=09120000000          # dev-only seeded admin account (in-memory store)

# Database (added in the backend layer)
DATABASE_URL=
