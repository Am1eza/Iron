# ── آهن‌تایم Web — environment (copy to .env.local; NEVER commit real secrets) ──

# Public (exposed to the browser — safe)
NEXT_PUBLIC_SITE_URL=https://ahantime.com
NEXT_PUBLIC_API_MODE=mock            # mock | live — "live" needs DATABASE_URL + SESSION_SECRET
NEXT_PUBLIC_DEPLOY_REGION=unknown    # free-form label, surfaced on /api/health — see GEO-ROUTING.md

# ── Server-only secrets (no NEXT_PUBLIC_ prefix; never reach the client) ──
# Database (Postgres; drives everything in live mode)
DATABASE_URL=                         # postgres://ahantime:...@localhost:5432/ahantime
SEED_ON_START=false                   # container entrypoint: seed empty tables on boot

# Auth / sessions
SESSION_SECRET=                       # ≥32 random chars; signs the access JWT (required in live)
AUTH_ENFORCED=false                   # true → middleware gates /admin on the session cookie
DEV_ADMIN_MOBILE=09120000000          # seeded admin account (memory store + db seed)
# ADMIN_MOBILES=09xxxxxxxxx,09xxxxxxxxx   # admin allowlist bootstrap: only these mobiles may hold the admin role

# SMS (OTP / پیش‌فاکتور / alerts) — SMS.ir. Blank → dev fallback (logged + sms_log).
# Required in live mode (OTP login has no fallback path once AUTH_ENFORCED=true).
SMSIR_API_KEY=
SMSIR_TEMPLATE_ID=                    # numeric OTP-verify template ID from the SMS.ir panel (placeholder #OTP#)
SMSIR_TEMPLATE_PARAM=OTP         # placeholder name inside the verify template (the text between # signs)
SMSIR_LINE_NUMBER=                    # sender line for free-text sends (پیش‌فاکتور/alerts) via /v1/send/bulk

# OTP provider — Kavenegar (PREFERRED for OTP: much faster handset delivery
# than the SMS.ir verify line, measured 90–210s on SMS.ir to MCI numbers).
# When BOTH are set, OTP goes via Kavenegar and SMS.ir stays as a backup.
# Leave blank to keep using SMS.ir. پیش‌فاکتور/alert texts still use SMS.ir.
KAVENEGAR_API_KEY=
KAVENEGAR_OTP_TEMPLATE=               # the OTP template NAME from the Kavenegar panel (message must contain %token)

# Market data (ticker) — tgju. Blank → seeded/last-known values keep serving
TGJU_BASE_URL=
TGJU_API_KEY=                         # only if your relay/base URL requires one

# AI advisor: DeepSeek via the out-of-Iran relay (OpenAI-compatible).
# Off by default; flipping AI_ENABLED=true requires the two keys below.
AI_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=                    # https://<relay-host>/v1
DEEPSEEK_MODEL=deepseek-chat
# Optional fallback relay (availability): with BOTH set, a primary failure
# retries the same request once against this OpenAI-compatible endpoint.
FALLBACK_BASE_URL=
FALLBACK_API_KEY=
FALLBACK_MODEL=                       # empty → reuse DEEPSEEK_MODEL

# Admin image uploads (article covers, SKU photos). Path is relative to the
# app's cwd unless absolute. In Docker this is mounted as a named volume
# (see docker-compose.yml `uploads:`) so files survive redeploys.
UPLOAD_DIR=public/uploads
