# ── Cloudflare Workers runtime secrets (OpenNext) ──
# Local: copy to `web/.dev.vars` for `pnpm cf:preview` (wrangler reads it).
# Production: set each with `wrangler secret put <NAME>` or in the dashboard
#   (Workers → ahantime → Settings → Variables and Secrets). NEVER commit real values.
#
# These mirror web/.env.example but apply to the deployed Worker on ahantime.com.

# AI: DeepSeek via the out-of-Iran relay (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://<relay-host>/v1
DEEPSEEK_MODEL=deepseek-chat

# SMS (OTP) — SMS.ir Verify API
SMSIR_API_KEY=
SMSIR_TEMPLATE_ID=

# Market data (ticker) — tgju
TGJU_BASE_URL=
TGJU_API_KEY=

# Auth / sessions
SESSION_SECRET=
AUTH_ENFORCED=true
DEV_ADMIN_MOBILE=09120000000

# Database
DATABASE_URL=
