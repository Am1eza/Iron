# ── Cloudflare Workers runtime secrets (OpenNext) ──
# Local: copy to `web/.dev.vars` for `pnpm cf:preview` (wrangler reads it).
# Production: set each with `wrangler secret put <NAME>` or in the dashboard
#   (Workers → ahantime → Settings → Variables and Secrets). NEVER commit real values.
#
# These mirror web/.env.example but apply to the deployed Worker on ahantime.com.

# AI: DeepSeek via the out-of-Iran relay (OpenAI-compatible).
# AI_ENABLED is the master switch checked by aiEnabled() — off by default;
# without it set to exactly "true" the advisor 503s ai_disabled even with
# valid DEEPSEEK_API_KEY/DEEPSEEK_BASE_URL set (this line was missing from
# this file, which DEPLOY-CLOUDFLARE.md points to as "the full list" — a
# real, silent trap for anyone following that doc literally).
AI_ENABLED=true
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://<relay-host>/v1
DEEPSEEK_MODEL=deepseek-chat
# Optional fallback relay (availability): when BOTH base URL and key are set,
# a primary failure retries the same OpenAI-compatible request once here.
# FALLBACK_MODEL empty → the primary DEEPSEEK_MODEL is reused.
FALLBACK_BASE_URL=
FALLBACK_API_KEY=
FALLBACK_MODEL=

# SMS (OTP) — SMS.ir Verify API
SMSIR_API_KEY=
SMSIR_TEMPLATE_ID=

# Market data (ticker) — tgju
TGJU_BASE_URL=
TGJU_API_KEY=

# Auth / sessions
SESSION_SECRET=
AUTH_ENFORCED=true
DEV_ADMIN_MOBILE=09120000000

# Database — postgres://user:pass@host:5432/db?sslmode=require
# If your provider offers a pooled endpoint (e.g. Neon's "-pooler" host), use
# it here for the Cloudflare Worker deployment; use the DIRECT endpoint for
# Docker/self-hosted (the job scheduler's advisory locks need one dedicated
# session — see DEPLOY-CLOUDFLARE.md's "Which connection string" note).
DATABASE_URL=
